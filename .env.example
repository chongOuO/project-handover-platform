# ============================================================
# 專案交接平台 — 環境變數設定範本
# 複製此檔案為 .env 後填入實際數值即可啟動服務
# cp .env.example .env
# ============================================================

# ---------- Google Gemini API ----------
# 必填：Google AI Studio 取得的 API Key
# 申請位址：https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# 選填：指定使用的 Gemini 模型（預設為 gemini-2.5-flash）
# 可選值：gemini-2.5-flash / gemini-2.5-pro / gemini-2.0-flash
LLM_MODEL_NAME=gemini-2.5-flash

# 選填：自訂 Gemini API 代理伺服器位址 (例如 Gemini Balance)
# GEMINI_BASE_URL=https://your-gemini-balance-url.com/api/v1
